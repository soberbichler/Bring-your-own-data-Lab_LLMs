    chat,
    config={
        "temperature": 0.0,
    },
)

chat.add_assistant_response(response)

print(response.content)

chat.add_user_message("What is the capital of Germany?")

response = model.respond(
    chat,
    config={
        "temperature": 0.0,
    },
)

